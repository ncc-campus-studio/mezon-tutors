{
  "$schema": "https://turborepo.org/schema.json",
  "globalEnv": [
    "DISABLE_EXTRACTION",
    "NODE_ENV",
    "EAS_BUILD_PLATFORM",
    "DATABASE_URL",
    "NEXT_PUBLIC_API_ENDPOINT",
    "IGNORE_TS_CONFIG_PATHS",
    "TAMAGUI_TARGET",
    "TAMAGUI_DISABLE_WARN_DYNAMIC_LOAD"
  ],
  "pipeline": {
    "build": {
      "env": [
        "DISABLE_EXTRACTION",
        "NODE_ENV",
        "EAS_BUILD_PLATFORM",
        "NEXT_PUBLIC_API_ENDPOINT",
        "IGNORE_TS_CONFIG_PATHS",
        "TAMAGUI_TARGET",
        "TAMAGUI_DISABLE_WARN_DYNAMIC_LOAD"
      ],
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "build/**",
        "node_modules/.cache/metro/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "lint": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
