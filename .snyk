# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.0
# Exclude false positives for hardcoded configuration keys
exclude:
  code:
    - '**/*'
ignore:
  'SNYK-JS-HARDCODED-SECRET':
    - '*':
        reason: 'False positive - configuration keys, not actual secrets'
        expires: '2026-12-31T00:00:00.000Z'