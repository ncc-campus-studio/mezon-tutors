{
  "framework": "nextjs",
  "installCommand": "cd ../.. && corepack enable && corepack prepare yarn@4.11.0 --activate && yarn install",
  "buildCommand": "yarn build",
  "build": {
    "env": {
      "NEXT_PUBLIC_API_ENDPOINT": "https://api.mezonly.site/api",
      "IGNORE_TS_CONFIG_PATHS": "true",
      "TAMAGUI_TARGET": "web",
      "TAMAGUI_DISABLE_WARN_DYNAMIC_LOAD": "1"
    }
  }
}